---
import Layout from "../../layouts/Layout.astro";
---

<Layout title="Files - Sub-Store">
  <div class="p-6 max-w-7xl mx-auto">
    <h2 class="text-2xl font-bold mb-2">Files</h2>
    <p class="text-gray-500 mb-6">Manage stored files and snippets</p>

    <div id="file-list" class="space-y-3">
      <p class="text-gray-500">Loading...</p>
    </div>
  </div>
</Layout>

<script>
  async function loadFiles() {
    try {
      const res = await fetch("/api/files");
      const data = await res.json();
      const el = document.getElementById("file-list")!;
      const items = data.items || [];
      if (items.length === 0) {
        el.textContent = "No files yet.";
        return;
      }
      el.textContent = "";
      for (const file of items) {
        const card = document.createElement("div");
        card.className = "card flex items-center justify-between";
        const info = document.createElement("div");
        const name = document.createElement("p");
        name.className = "font-medium";
        name.textContent = file.name || "Unnamed";
        const meta = document.createElement("p");
        meta.className = "text-sm text-gray-500";
        meta.textContent = file.content ? `${String(file.content).length} chars` : "No content";
        info.appendChild(name);
        info.appendChild(meta);
        card.appendChild(info);
        el.appendChild(card);
      }
    } catch (e) {
      document.getElementById("file-list")!.textContent = "Failed to load";
    }
  }
  loadFiles();
</script>
