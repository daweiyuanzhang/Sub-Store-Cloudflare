{
    "name": "sub-store-cloudflare",
    "version": "1.0.0",
    "description": "Sub-Store Cloudflare adapter for Workers and Pages",
    "type": "module",
    "scripts": {
        "prepare:quickjs-wasm": "bash scripts/copy-quickjs-wasm.sh",
        "dev": "pnpm run prepare:quickjs-wasm && vite dev --host 0.0.0.0 --port 3000",
        "build": "pnpm run prepare:quickjs-wasm && vite build",
        "build:worker": "bash scripts/build-worker.sh",
        "build:worker-rs": "cd worker-rs && pnpm exec wrangler deploy --dry-run --outdir dist",
        "build:pages": "bash scripts/build-pages-frontend.sh",
        "preview": "pnpm run prepare:quickjs-wasm && vite preview --host 0.0.0.0 --port 3000",
        "fetch:substore": "bash scripts/fetch-substore.sh",
        "install:backend": "cd sub-store/backend && pnpm install",
        "deploy:local": "pnpm run prepare:quickjs-wasm && pnpm exec wrangler deploy",
        "tail": "pnpm exec wrangler tail --format=pretty"
    },
    "devDependencies": {
        "@cloudflare/vite-plugin": "latest",
        "@vitejs/plugin-react": "latest",
        "vite": "latest",
        "wrangler": "latest"
    },
    "dependencies": {
        "@cloudflare/actors": "latest",
        "@marsidev/react-turnstile": "latest",
        "@jitl/quickjs-wasmfile-release-sync": "latest",
        "buffer": "latest",
        "jose": "latest",
        "mmdb-lib": "latest",
        "quickjs-emscripten": "latest",
        "react": "latest",
        "react-dom": "latest",
        "react-router-dom": "latest"
    }
}
